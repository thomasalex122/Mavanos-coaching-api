generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  
}


model User {
  id Int @id @default(autoincrement())
  name String 
  email String @unique 
  password String 
  role Role @default(STUDENT)
  bookings Booking[]
}


model Session {
  id Int @id @default(autoincrement())
  title String 
  date DateTime 
  maxSlots Int
  bookings Booking[]
  
}

model Booking {
  id Int @id @default(autoincrement())
  user User @relation(fields : [userId] , references : [id])
  userId Int
  session Session @relation(fields: [sessionId] , references:[id])
  sessionId Int 

  @@unique([userId , sessionId])

}

enum Role{
  STUDENT
  COACH
}